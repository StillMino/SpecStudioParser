<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecStudioParser.ViewModels"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        x:Class="SpecStudioParser.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Конструктор Спецификаций nanoCAD"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner">

	<Grid RowDefinitions="*, Auto">

		<Grid Grid.Row="0" Margin="20" RowDefinitions="Auto, *, Auto" IsVisible="{Binding IsProfileNotLoaded}">

			<Border Grid.Row="0" Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0,0,0,15">
				<Grid ColumnDefinitions="*, Auto">
					<StackPanel Grid.Column="0">
						<TextBlock Text="Корневая папка профилей XML спецификаций:" FontWeight="Bold" FontSize="11" Foreground="#555555"/>
						<TextBox Text="{Binding RootProfilesPath, Mode=TwoWay}" Watermark="Путь к папке XML-профилей" Margin="0,4,0,0"/>
						<TextBlock Text="Введите путь к папке профилей вручную и нажмите 'Применить путь'. Если папки нет, она будет создана." TextWrapping="Wrap" Margin="0,4,0,0" FontSize="11" Foreground="#475569"/>
					</StackPanel>
					<Button Grid.Column="1" Content="Применить путь" Click="ApplyProfileFolderClick" VerticalAlignment="Center" Margin="10,0,0,0"/>
				</Grid>
			</Border>

			<Grid Grid.Row="1" ColumnDefinitions="*, 300" Margin="0,0,0,15">
				<Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="White">
					<Grid RowDefinitions="Auto, Auto, *">
						<Border Grid.Row="0" Background="#EAEAEA" Padding="8">
							<TextBlock Text="Доступные конфигурации спецификаций в папке:" FontWeight="Bold"/>
						</Border>

						<Border Grid.Row="1" Background="#F8FAFC" Padding="10" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
							<TextBlock Text="Если список ниже пуст, XML-профили ещё не сохранены в указанной папке. Создайте новый профиль или импортируйте существующий XML Model Studio." TextWrapping="Wrap" FontSize="12" Foreground="#475569"/>
						</Border>

						<ListBox Grid.Row="2" ItemsSource="{Binding AvailableXmlFiles}" SelectedItem="{Binding SelectedXmlFile}">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="system:String">
									<Border Padding="4">
										<StackPanel Orientation="Horizontal">
											<Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M13,9V3.5L18.5,9H13Z" Fill="#FFB74D" Width="16" Height="16" Margin="0,0,8,0"/>
											<TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13"/>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>

				<StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="10">
					<Button Content="Открыть выбранную спецификацию" Command="{Binding LoadSelectedXmlCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="12" Background="#1E88E5" Foreground="White" FontWeight="Bold"/>
					<Button Content="Создать новую спецификацию" Command="{Binding CreateNewProfileCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#4CAF50" Foreground="White"/>
					<Button Content="Импортировать внешний XML..." Click="ImportXmlClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>
					<Border Background="#FFF3E0" CornerRadius="4" Padding="10" Margin="0,10,0,0">
						<TextBlock Text="После создания нового профиля откроется рабочий экран. Чтобы записать XML в папку профилей, используйте кнопку 'Сохранить изменения' в верхней панели. Кнопка 'Сохранить профиль XML' в окне настроек экспортирует копию на рабочий стол." TextWrapping="Wrap" FontSize="11" Foreground="#E65100"/>
					</Border>
				</StackPanel>
			</Grid>
		</Grid>

		<Grid Grid.Row="0" RowDefinitions="Auto, *" IsVisible="{Binding IsProfileLoaded}">
			<Border Grid.Row="0" Background="#E0F2F1" BorderBrush="#B2DFDB" BorderThickness="0,0,0,1" Padding="10">
				<Grid ColumnDefinitions="Auto, *, Auto, Auto">
					<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
						<Button Content="← К списку XML" Command="{Binding CloseProfileCommand}" Margin="0,0,15,0" HotKey="Escape"/>
						<TextBlock Text="Активный XML профиль: " FontWeight="Bold" VerticalAlignment="Center"/>
					</StackPanel>
					<TextBox Grid.Column="1" Text="{Binding SelectedXmlFile}" Watermark="Имя_файла.xml" VerticalAlignment="Center" Margin="5,0,15,0"/>
					<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
						<Button Command="{Binding ScanAllCommand}" Width="32" Height="28" Padding="4" ToolTip.Tip="Получить данные с чертежа">
							<Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Fill="#1565C0" Width="16" Height="16" Stretch="Uniform"/>
						</Button>
						<Button Content="Сохранить изменения" Command="{Binding SaveCurrentProfileCommand}" Background="#00897B" Foreground="White" FontWeight="Bold"/>
						<Button Content="Настройки структуры данных" Command="{Binding OpenSettingsWindowCommand}" Background="#78909C" Foreground="White"/>
					</StackPanel>
				</Grid>
			</Border>
			<Grid Grid.Row="1" ColumnDefinitions="*, 2*" Margin="10">
				<HeaderedContentControl Grid.Column="0" Header="Кэш элементов чертежа" Margin="0,0,5,0">
					<DataGrid Name="AnalyzerGrid"
							  ItemsSource="{Binding GridItems}"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  SelectionMode="Extended"
							  CanUserSortColumns="True"
							  GridLinesVisibility="All">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Handle" Binding="{Binding Handle}" Width="90"/>
							<DataGridTextColumn Header="Тип / наименование" Binding="{Binding ObjectName}" Width="*"/>
							<DataGridTextColumn Header="Слой" Binding="{Binding Layer}" Width="120"/>
							<DataGridTextColumn Header="Источник" Binding="{Binding ModelStudioId}" Width="130"/>
							<DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="2*"/>
						</DataGrid.Columns>
					</DataGrid>
				</HeaderedContentControl>

				<HeaderedContentControl Grid.Column="1" Header="Сформированная спецификация" Margin="5,0,0,0">
					<DataGrid Name="SpecGrid"
							  ItemsSource="{Binding SpecificationRows}"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  SelectionMode="Extended"
							  CanUserSortColumns="True"
							  GridLinesVisibility="All"/>
				</HeaderedContentControl>
			</Grid>
		</Grid>

		<Border Grid.Row="1" Background="#263238" Padding="6">
			<Grid ColumnDefinitions="*, Auto">
				<TextBlock Grid.Column="0" Text="{Binding ConnectionStatus}" Foreground="#ECEFF1" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
				<TextBlock Grid.Column="1" Text="SpecStudio v1.2" Foreground="#90A4AE" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
			</Grid>
		</Border>

	</Grid>
</Window>
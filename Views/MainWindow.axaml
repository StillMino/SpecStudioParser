<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecStudioParser.ViewModels"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        x:Class="SpecStudioParser.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Конструктор Спецификаций nanoCAD"
        Width="1100" Height="700"
        Background="#F7F7F5"
        WindowStartupLocation="CenterOwner">

	<Grid RowDefinitions="*, Auto" Background="#F7F7F5">

		<Grid Grid.Row="0" Margin="20" RowDefinitions="Auto, *, Auto" IsVisible="{Binding IsProfileNotLoaded}">

			<Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D0CC" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,15">
				<Grid ColumnDefinitions="*, Auto, Auto">
					<StackPanel Grid.Column="0">
						<TextBlock Text="Корневая папка профилей XML спецификаций:" FontWeight="Bold" FontSize="11" Foreground="#1F1F1F"/>
						<TextBox Text="{Binding RootProfilesPath, Mode=TwoWay}" Watermark="Путь к папке XML-профилей" Margin="0,4,0,0"/>
						<TextBlock Text="Выберите папку профилей через проводник или введите путь вручную и нажмите 'Применить путь'. Если папки нет, она будет создана." TextWrapping="Wrap" Margin="0,4,0,0" FontSize="11" Foreground="#5F6368"/>
					</StackPanel>
					<Button Grid.Column="1" Click="ChooseProfileFolderClick" VerticalAlignment="Center" Margin="10,0,0,0" Padding="10,6" Background="#FFFFFF" Foreground="#1F1F1F" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="Выбрать папку профилей через проводник">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<Path Data="M10 4H2C.9 4 0 4.9 0 6v12c0 1.1.9 2 2 2h20c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H12l-2-2z" Fill="#B76E2B" Width="14" Height="14" Stretch="Uniform"/>
							<TextBlock Text="Папка" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="2" Click="ApplyProfileFolderClick" VerticalAlignment="Center" Margin="8,0,0,0" Padding="10,6" Background="#F3E6DA" Foreground="#1F1F1F" BorderBrush="#B76E2B" BorderThickness="1" ToolTip.Tip="Применить путь из поля ввода">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<Path Data="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z" Fill="#B76E2B" Width="14" Height="14" Stretch="Uniform"/>
							<TextBlock Text="Применить" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</Grid>
			</Border>

			<Grid Grid.Row="1" ColumnDefinitions="*, 300" Margin="0,0,0,15">
				<Border Grid.Column="0" BorderBrush="#D0D0CC" BorderThickness="1" CornerRadius="4" Background="#FFFFFF">
					<Grid RowDefinitions="Auto, Auto, Auto, *">
						<Border Grid.Row="0" Background="#242424" Padding="8">
							<TextBlock Text="Доступные конфигурации спецификаций в папке:" FontWeight="Bold" Foreground="#FFFFFF"/>
						</Border>

						<Border Grid.Row="1" Background="#FFFFFF" Padding="10" BorderBrush="#D0D0CC" BorderThickness="0,0,0,1">
							<TextBlock Text="Если список ниже пуст, XML-профили ещё не сохранены в указанной папке. Создайте новый профиль или импортируйте существующий XML Model Studio." TextWrapping="Wrap" FontSize="12" Foreground="#5F6368"/>
						</Border>

						<TextBox Name="ProfileSearchBox" Grid.Row="2" Watermark="Поиск профиля..." Margin="10" TextChanged="ProfileSearchTextChanged"/>

						<ListBox Grid.Row="3" ItemsSource="{Binding AvailableXmlFiles}" SelectedItem="{Binding SelectedXmlFile}" Background="#FFFFFF" Foreground="#1F1F1F">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="system:String">
									<Border Padding="4">
										<StackPanel Orientation="Horizontal">
											<Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M13,9V3.5L18.5,9H13Z" Fill="#B76E2B" Width="16" Height="16" Margin="0,0,8,0"/>
											<TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13" Foreground="#1F1F1F"/>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Grid>
				</Border>

				<StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="10">
					<Button Command="{Binding LoadSelectedXmlCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#F3E6DA" Foreground="#1F1F1F" BorderBrush="#B76E2B" BorderThickness="1" FontWeight="Bold" ToolTip.Tip="Открыть выбранный XML-профиль">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Path Data="M8 5v14l11-7z" Fill="#B76E2B" Width="14" Height="14" Stretch="Uniform"/>
							<TextBlock Text="Открыть" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Command="{Binding CreateNewProfileCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#FFFFFF" Foreground="#1F1F1F" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="Создать новый XML-профиль">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Fill="#B76E2B" Width="14" Height="14" Stretch="Uniform"/>
							<TextBlock Text="Создать" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Click="ImportXmlClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#FFFFFF" Foreground="#1F1F1F" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="Импортировать внешний XML Model Studio">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Path Data="M5 20h14v-2H5m14-9h-4V3H9v6H5l7 7 7-7z" Fill="#B76E2B" Width="14" Height="14" Stretch="Uniform"/>
							<TextBlock Text="Импорт" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Border Background="#FFFFFF" BorderBrush="#D0D0CC" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,10,0,0">
						<TextBlock Text="После создания нового профиля откроется рабочий экран. Для записи XML используйте кнопку сохранения в верхней панели." TextWrapping="Wrap" FontSize="11" Foreground="#5F6368"/>
					</Border>
				</StackPanel>
			</Grid>
		</Grid>

		<Grid Grid.Row="0" RowDefinitions="Auto, *" IsVisible="{Binding IsProfileLoaded}">
			<Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D0D0CC" BorderThickness="0,0,0,1" Padding="10">
				<Grid ColumnDefinitions="Auto, *, Auto">
					<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
						<Button Content="←" Command="{Binding CloseProfileCommand}" Width="32" Height="28" Padding="4" Margin="0,0,10,0" HotKey="Escape" Background="#FFFFFF" Foreground="#1F1F1F" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="К списку XML-профилей"/>
						<TextBlock Text="XML профиль:" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1F1F1F"/>
					</StackPanel>
					<TextBox Grid.Column="1" Text="{Binding SelectedXmlFile}" Watermark="Имя_файла.xml" VerticalAlignment="Center" Margin="5,0,15,0"/>
					<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
						<Button Command="{Binding ScanAllCommand}" Width="32" Height="28" Padding="4" Background="#FFFFFF" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="Получить данные с чертежа">
							<Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" Fill="#B76E2B" Width="16" Height="16" Stretch="Uniform"/>
						</Button>
						<Button Command="{Binding SaveCurrentProfileCommand}" Width="32" Height="28" Padding="4" Background="#F3E6DA" BorderBrush="#B76E2B" BorderThickness="1" ToolTip.Tip="Сохранить XML-профиль в выбранную папку">
							<Path Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zM12 19c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zM6 8V5h9v3H6z" Fill="#B76E2B" Width="16" Height="16" Stretch="Uniform"/>
						</Button>
						<Button Command="{Binding OpenSettingsWindowCommand}" Width="32" Height="28" Padding="4" Background="#FFFFFF" BorderBrush="#D0D0CC" BorderThickness="1" ToolTip.Tip="Настройка наборов данных, колонок и фильтров">
							<Path Data="M19.43 12.98c.04-.32.07-.65.07-.98s-.02-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.37-.31-.6-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98L14.5 2.42C14.47 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.5.42L9.12 5.07c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.08-.48 0-.6.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.08.65-.08.98s.03.66.08.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.37.31.6.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.04.24.25.42.5.42h4c.25 0 .47-.18.5-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.08.48 0 .6-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5z" Fill="#B76E2B" Width="16" Height="16" Stretch="Uniform"/>
						</Button>
					</StackPanel>
				</Grid>
			</Border>
			<Grid Grid.Row="1" ColumnDefinitions="*, 2*" Margin="10">
				<HeaderedContentControl Grid.Column="0" Header="Кэш элементов чертежа" Margin="0,0,5,0">
					<DataGrid Name="AnalyzerGrid"
							  ItemsSource="{Binding GridItems}"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  SelectionMode="Extended"
							  CanUserSortColumns="True"
							  GridLinesVisibility="All">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Handle" Binding="{Binding Handle}" Width="90"/>
							<DataGridTextColumn Header="Тип / наименование" Binding="{Binding ObjectName}" Width="*"/>
							<DataGridTextColumn Header="Слой" Binding="{Binding Layer}" Width="120"/>
							<DataGridTextColumn Header="Источник" Binding="{Binding ModelStudioId}" Width="130"/>
							<DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="2*"/>
						</DataGrid.Columns>
					</DataGrid>
				</HeaderedContentControl>

				<HeaderedContentControl Grid.Column="1" Header="Сформированная спецификация" Margin="5,0,0,0">
					<DataGrid Name="SpecGrid"
							  ItemsSource="{Binding SpecificationRows}"
							  AutoGenerateColumns="False"
							  IsReadOnly="True"
							  SelectionMode="Extended"
							  CanUserSortColumns="True"
							  GridLinesVisibility="All"/>
				</HeaderedContentControl>
			</Grid>
		</Grid>

		<Border Grid.Row="1" Background="#242424" Padding="6">
			<Grid ColumnDefinitions="*, Auto">
				<TextBlock Grid.Column="0" Text="{Binding ConnectionStatus}" Foreground="#FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="5,0,0,0"/>
				<TextBlock Grid.Column="1" Text="SpecStudio v1.2" Foreground="#D8A06B" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
			</Grid>
		</Border>

	</Grid>
</Window>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibParameterBrowserWindow"
        x:DataType="cadlib:CadLibParameterBrowserViewModel"
        Title="Параметры CADLib БД"
        Width="1000"
        Height="650"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12" Background="{StaticResource AppBackgroundBrush}">
        <Grid Grid.Row="0" ColumnDefinitions="220,*" Margin="0,0,0,10">
            <TextBox Grid.Column="0" Watermark="Категории" IsEnabled="False"/>
            <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Поиск параметров" Margin="10,0,0,0"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="220,*">
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1" Padding="8">
                        <TextBlock Text="Категории" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}"/>
                </Grid>
            </Border>

            <DataGrid Grid.Column="1" ItemsSource="{Binding Parameters}" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True" GridLinesVisibility="All" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="180"/>
                    <DataGridTextColumn Header="Системное имя" Binding="{Binding SystemName}" Width="220"/>
                    <DataGridTextColumn Header="Отображаемое имя" Binding="{Binding DisplayName}" Width="260"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding TypeId}" Width="70"/>
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                    <DataGridTextColumn Header="idParamDef" Binding="{Binding IdParamDef}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}"/>
            <Button Grid.Column="1" Classes="neutralButton" Content="Закрыть" Command="{Binding CloseCommand}"/>
        </Grid>
    </Grid>
</Window>

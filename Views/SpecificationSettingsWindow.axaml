<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SpecStudioParser.ViewModels"
        xmlns:m="clr-namespace:SpecStudioParser.Models"
        x:Class="SpecStudioParser.Views.SpecificationSettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Конфигурация спецификации"
        Height="700" Width="960"
        Topmost="False"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">

	<Window.Resources>
		<StreamGeometry x:Key="IconSettings">M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z</StreamGeometry>
		<StreamGeometry x:Key="IconSave">M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z</StreamGeometry>
		<StreamGeometry x:Key="IconPlus">M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z</StreamGeometry>
		<StreamGeometry x:Key="IconUp">M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z</StreamGeometry>
		<StreamGeometry x:Key="IconDown">M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z</StreamGeometry>
		<StreamGeometry x:Key="IconDelete">M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z</StreamGeometry>
		<StreamGeometry x:Key="IconFolder">M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</StreamGeometry>
		<StreamGeometry x:Key="IconBack">M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z</StreamGeometry>
	</Window.Resources>

	<Grid RowDefinitions="Auto, *, Auto" Margin="15" Background="{StaticResource AppBackgroundBrush}">
		<Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,15">
			<Grid ColumnDefinitions="Auto, *, Auto">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Spacing="6">
					<PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16" Foreground="{StaticResource AccentBrush}"/>
					<TextBlock Text="Параметры шаблона:" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
				</StackPanel>
				<TextBox Grid.Column="1" Text="{Binding ActiveProfile.Name, Mode=TwoWay}" Watermark="Имя файла спецификации" VerticalContentAlignment="Center"/>
				<Button Grid.Column="2" Classes="accentButton" Command="{Binding GenerateSpecificationCommand}" Margin="10,0,0,0" VerticalContentAlignment="Center" ToolTip.Tip="Сгенерировать спецификацию по текущим настройкам">
					<StackPanel Orientation="Horizontal" Spacing="6">
						<PathIcon Data="{StaticResource IconSave}" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
						<TextBlock Text="Генерация" VerticalAlignment="Center"/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>

		<Grid Grid.Row="1">
			<Grid IsVisible="{Binding !IsDatasetEditorActive}" ColumnDefinitions="*, 160" Margin="0,10,0,0">
				<DataGrid Grid.Column="0" Name="DatasetsGrid" ItemsSource="{Binding ActiveProfile.Datasets}" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="False" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
					<DataGrid.Columns>
						<DataGridTextColumn Header="Название набора" Binding="{Binding Caption}" Width="2*"/>
						<DataGridTextColumn Header="Типов САПР" Binding="{Binding TargetTypes.Count}" Width="150"/>
						<DataGridTextColumn Header="Колонок" Binding="{Binding Columns.Count}" Width="120"/>
					</DataGrid.Columns>
				</DataGrid>

				<StackPanel Grid.Column="1" Spacing="8" Margin="12,0,0,0">
					<Button Classes="neutralButton commandButton" Command="{Binding AddDatasetCommand}">
						<StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconPlus}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Создать"/></StackPanel>
					</Button>
					<Button Classes="neutralButton commandButton" Command="{Binding MoveDatasetUpCommand}" CommandParameter="{Binding #DatasetsGrid.SelectedItem}">
						<StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconUp}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Выше"/></StackPanel>
					</Button>
					<Button Classes="neutralButton commandButton" Command="{Binding MoveDatasetDownCommand}" CommandParameter="{Binding #DatasetsGrid.SelectedItem}">
						<StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconDown}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Ниже"/></StackPanel>
					</Button>
					<Button Classes="dangerButton commandButton" Command="{Binding RemoveDatasetCommand}" CommandParameter="{Binding #DatasetsGrid.SelectedItem}">
						<StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconDelete}" Width="12" Height="12" Foreground="{StaticResource DangerBrush}"/><TextBlock Text="Удалить"/></StackPanel>
					</Button>
					<Separator Margin="0,5"/>
					<Button Classes="accentButton commandButton" Command="{Binding ConfigureSelectedDatasetCommand}" CommandParameter="{Binding #DatasetsGrid.SelectedItem}" Height="38">
						<TextBlock Text="Настроить" FontWeight="SemiBold" HorizontalAlignment="Center"/>
					</Button>
				</StackPanel>
			</Grid>

			<Grid IsVisible="{Binding IsDatasetEditorActive}" RowDefinitions="Auto, *" Margin="0,10,0,0">
				<Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
					<Grid ColumnDefinitions="Auto, Auto, *">
						<Button Grid.Column="0" Classes="neutralButton" Command="{Binding BackToDatasetListCommand}" VerticalContentAlignment="Center" ToolTip.Tip="Вернуться к списку наборов данных">
							<StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconBack}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Назад"/></StackPanel>
						</Button>
						<TextBlock Grid.Column="1" Text="Набор:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" Margin="10,0,0,0"/>
						<TextBox Grid.Column="2" Text="{Binding SelectedDataset.Caption, Mode=TwoWay}" Watermark="Название набора данных" VerticalContentAlignment="Center" Margin="10,0,0,0"/>
					</Grid>
				</Border>

				<TabControl Grid.Row="1">
					<TabItem Header="Фильтры">
						<Grid ColumnDefinitions="1.15*, 1.85*" Margin="0,10,0,0">
							<StackPanel Grid.Column="0" Spacing="5" Margin="5">
								<Label Content="Типы объектов САПР" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
								<TextBox Text="{Binding TypeSearchText, Mode=TwoWay}" Watermark="Поиск по типам объектов..." VerticalContentAlignment="Center"/>
								<Grid ColumnDefinitions="*,*,*" Margin="0,5">
									<Button Grid.Column="0" Classes="neutralButton" Content="Все" Command="{Binding SelectAllTypesCmd}" FontSize="10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,2,0"/>
									<Button Grid.Column="1" Classes="neutralButton" Content="Снять" Command="{Binding UnselectAllTypesCmd}" FontSize="10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0,2,0"/>
									<Button Grid.Column="2" Classes="neutralButton" Content="Инверт" Command="{Binding InvertTypesCmd}" FontSize="10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0,0,0"/>
								</Grid>
								<ListBox ItemsSource="{Binding FilteredTypeItems}" Height="280" Background="{StaticResource PanelBrush}">
									<ListBox.ItemTemplate><DataTemplate x:DataType="m:CheckableTypeItem"><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Content="{Binding TypeName}"/></DataTemplate></ListBox.ItemTemplate>
								</ListBox>
							</StackPanel>

							<HeaderedContentControl Grid.Column="1" Header="Конструктор условий" Margin="10,0,0,0">
								<Grid RowDefinitions="Auto, *, Auto" Margin="5">
									<Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,8">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<TextBlock Text="Связь старых условий:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
											<ComboBox Width="90" ItemsSource="{Binding SelectedDataset.RootFilterGroup.AvailableJoinOperators}" SelectedItem="{Binding SelectedDataset.RootFilterGroup.JoinOperator, Mode=TwoWay}" ToolTip.Tip="Используется только для совместимости со старым плоским списком условий"/>
											<TextBlock Text="Для новых строк связь задаётся в поле справа" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
										</StackPanel>
									</Border>
									<ScrollViewer Grid.Row="1">
										<ItemsControl ItemsSource="{Binding SelectedDataset.RootFilterItems}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="m:FilterRootItem">
													<StackPanel Spacing="8">
														<Border IsVisible="{Binding IsCondition}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource PanelBrush}" Padding="6" Margin="0,3">
															<Grid ColumnDefinitions="Auto, *, 100, *, 80, Auto">
																<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" Margin="0,0,6,0">
																	<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveRootFilterItemUpClick" ToolTip.Tip="Переместить выше"><PathIcon Data="{StaticResource IconUp}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																	<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveRootFilterItemDownClick" ToolTip.Tip="Переместить ниже"><PathIcon Data="{StaticResource IconDown}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																</StackPanel>
																<ComboBox Grid.Column="1" ItemsSource="{Binding Condition.AvailableAttributes}" SelectedItem="{Binding Condition.Attribute, Mode=TwoWay}"/>
																<ComboBox Grid.Column="2" ItemsSource="{Binding Condition.AvailableOperators}" SelectedItem="{Binding Condition.Operator, Mode=TwoWay}" Margin="4,0"/>
																<TextBox Grid.Column="3" Text="{Binding Condition.Value, Mode=TwoWay}" Watermark="Значение"/>
																<ComboBox Grid.Column="4" ItemsSource="{Binding Condition.AvailableJoinOperators}" SelectedItem="{Binding Condition.JoinWithNext, Mode=TwoWay}" Margin="4,0" ToolTip.Tip="Связь со следующим элементом; у последнего элемента не используется"/>
																<Button Grid.Column="5" Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="RemoveRootFilterItemClick" Margin="4,0,0,0" ToolTip.Tip="Удалить условие"><PathIcon Data="{StaticResource IconDelete}" Width="12" Height="12" Foreground="{StaticResource DangerBrush}"/></Button>
															</Grid>
														</Border>

														<Border IsVisible="{Binding IsGroup}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,6,0,0" Background="{StaticResource PanelBrush}">
															<StackPanel Spacing="6">
																<Grid ColumnDefinitions="4, *">
																	<Border Grid.Column="0" Background="{StaticResource AccentBrush}" CornerRadius="2" Margin="0,2,0,2"/>
																	<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
																		<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveRootFilterItemUpClick" ToolTip.Tip="Переместить выше"><PathIcon Data="{StaticResource IconUp}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																		<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveRootFilterItemDownClick" ToolTip.Tip="Переместить ниже"><PathIcon Data="{StaticResource IconDown}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																		<TextBlock Text="Группа" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
																		<ComboBox Width="90" ItemsSource="{Binding Group.AvailableJoinOperators}" SelectedItem="{Binding Group.JoinWithNext, Mode=TwoWay}" ToolTip.Tip="Связь со следующим корневым элементом; у последней группы не используется"/>
																		<Button Classes="neutralButton" DataContext="{Binding Group}" Click="GroupSelectedNestedFilterItemsClick" Content="Сгруппировать выбранные" Padding="6,2" ToolTip.Tip="Группирует только соседние выбранные элементы внутри этой группы"/>
																		<Button Classes="neutralButton" DataContext="{Binding Group}" Click="AddConditionToGroupClick" Content="+ Условие" Padding="6,2"/>
																		<Button Classes="neutralButton" DataContext="{Binding Group}" Click="AddNestedGroupToGroupClick" Content="+ Подгруппа" Padding="6,2"/>
																		<Button Classes="dangerButton" Click="RemoveRootFilterItemClick" Content="Удалить" Padding="6,2"/>
																	</StackPanel>
																</Grid>
																<ItemsControl ItemsSource="{Binding Group.Items}">
																	<ItemsControl.ItemTemplate>
																		<DataTemplate x:DataType="m:FilterGroupItem">
																			<StackPanel>
																				<Border IsVisible="{Binding IsCondition}" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6" Margin="12,3,0,3">
																					<Grid ColumnDefinitions="Auto, Auto, *, 100, *, 80, Auto">
																						<CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="Выбрать для группировки"/>
																						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,0,6,0">
																							<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemUpClick" ToolTip.Tip="Переместить выше"><PathIcon Data="{StaticResource IconUp}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																							<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemDownClick" ToolTip.Tip="Переместить ниже"><PathIcon Data="{StaticResource IconDown}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																						</StackPanel>
																						<ComboBox Grid.Column="2" ItemsSource="{Binding Condition.AvailableAttributes}" SelectedItem="{Binding Condition.Attribute, Mode=TwoWay}"/>
																						<ComboBox Grid.Column="3" ItemsSource="{Binding Condition.AvailableOperators}" SelectedItem="{Binding Condition.Operator, Mode=TwoWay}" Margin="4,0"/>
																						<TextBox Grid.Column="4" Text="{Binding Condition.Value, Mode=TwoWay}" Watermark="Значение"/>
																						<ComboBox Grid.Column="5" ItemsSource="{Binding Condition.AvailableJoinOperators}" SelectedItem="{Binding Condition.JoinWithNext, Mode=TwoWay}" Margin="4,0" ToolTip.Tip="Связь со следующим элементом внутри группы; у последнего элемента не используется"/>
																						<Button Grid.Column="6" DataContext="{Binding Condition}" Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="RemoveFilterConditionClick" Margin="4,0,0,0" ToolTip.Tip="Удалить условие"><PathIcon Data="{StaticResource IconDelete}" Width="12" Height="12" Foreground="{StaticResource DangerBrush}"/></Button>
																					</Grid>
																				</Border>
																				<Border IsVisible="{Binding IsGroup}" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6" Margin="22,5,0,5">
																					<StackPanel Spacing="5">
																						<StackPanel Orientation="Horizontal" Spacing="8">
																							<CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" ToolTip.Tip="Выбрать для группировки"/>
																							<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemUpClick" ToolTip.Tip="Переместить выше"><PathIcon Data="{StaticResource IconUp}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																							<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemDownClick" ToolTip.Tip="Переместить ниже"><PathIcon Data="{StaticResource IconDown}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																							<TextBlock Text="Подгруппа" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
																							<ComboBox Width="90" ItemsSource="{Binding Group.AvailableJoinOperators}" SelectedItem="{Binding Group.JoinWithNext, Mode=TwoWay}" ToolTip.Tip="Связь со следующим элементом внутри родительской группы"/>
																							<Button Classes="neutralButton" DataContext="{Binding Group}" Click="AddConditionToGroupClick" Content="+ Условие" Padding="6,2"/>
																							<Button Classes="neutralButton" DataContext="{Binding Group}" Click="PromoteNestedFilterGroupClick" Content="Поднять" Padding="6,2" ToolTip.Tip="Поднять подгруппу на корневой уровень"/>
																							<Button Classes="neutralButton" DataContext="{Binding Group}" Click="DissolveNestedFilterGroupClick" Content="Расформировать" Padding="6,2" ToolTip.Tip="Удалить оболочку подгруппы, оставив её условия в родительской группе"/>
																							<Button Classes="dangerButton" DataContext="{Binding Group}" Click="RemoveNestedFilterGroupClick" Content="Удалить" Padding="6,2"/>
																						</StackPanel>
																						<ItemsControl ItemsSource="{Binding Group.Items}">
																							<ItemsControl.ItemTemplate>
																								<DataTemplate x:DataType="m:FilterGroupItem">
																									<Border IsVisible="{Binding IsCondition}" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6" Margin="12,3,0,3">
																										<Grid ColumnDefinitions="Auto, *, 100, *, 80, Auto">
																											<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" Margin="0,0,6,0">
																												<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemUpClick" ToolTip.Tip="Переместить выше"><PathIcon Data="{StaticResource IconUp}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																												<Button Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="MoveNestedFilterGroupItemDownClick" ToolTip.Tip="Переместить ниже"><PathIcon Data="{StaticResource IconDown}" Width="10" Height="10" Foreground="{StaticResource AccentBrush}"/></Button>
																											</StackPanel>
																											<ComboBox Grid.Column="1" ItemsSource="{Binding Condition.AvailableAttributes}" SelectedItem="{Binding Condition.Attribute, Mode=TwoWay}"/>
																											<ComboBox Grid.Column="2" ItemsSource="{Binding Condition.AvailableOperators}" SelectedItem="{Binding Condition.Operator, Mode=TwoWay}" Margin="4,0"/>
																											<TextBox Grid.Column="3" Text="{Binding Condition.Value, Mode=TwoWay}" Watermark="Значение"/>
																											<ComboBox Grid.Column="4" ItemsSource="{Binding Condition.AvailableJoinOperators}" SelectedItem="{Binding Condition.JoinWithNext, Mode=TwoWay}" Margin="4,0"/>
																											<Button Grid.Column="5" DataContext="{Binding Condition}" Classes="neutralButton iconMiniButton" Width="26" Height="26" Click="RemoveFilterConditionClick" Margin="4,0,0,0" ToolTip.Tip="Удалить условие"><PathIcon Data="{StaticResource IconDelete}" Width="12" Height="12" Foreground="{StaticResource DangerBrush}"/></Button>
																										</Grid>
																									</Border>
																								</DataTemplate>
																							</ItemsControl.ItemTemplate>
																						</ItemsControl>
																					</StackPanel>
																				</Border>
																			</StackPanel>
																		</DataTemplate>
																	</ItemsControl.ItemTemplate>
																</ItemsControl>
															</StackPanel>
														</Border>
													</StackPanel>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</ScrollViewer>
									<StackPanel Grid.Row="2" Spacing="6" Margin="0,10,0,0">
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Button Classes="neutralButton" Click="AddRootConditionClick" HorizontalAlignment="Left" Content="+ Условие"/>
											<Button Classes="neutralButton" Click="AddFilterGroupClick" HorizontalAlignment="Left" Content="+ Группа"/>
										</StackPanel>
										<Border Background="{StaticResource AccentSoftBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" CornerRadius="4" Padding="6">
											<StackPanel Spacing="3">
												<TextBlock Text="Итоговая формула" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}"/>
												<TextBlock Text="{Binding SelectedDataset.FilterFormula}" FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
											</StackPanel>
										</Border>
									</StackPanel>
								</Grid>
							</HeaderedContentControl>
						</Grid>
					</TabItem>

					<TabItem Header="Столбцы и поля">
						<Grid ColumnDefinitions="*, 150" Margin="0,10,0,0">
							<DataGrid Grid.Column="0" Name="FieldsGrid" ItemsSource="{Binding SelectedDataset.Columns}" AutoGenerateColumns="False" CanUserSortColumns="False" GridLinesVisibility="All" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" RowHeight="NaN">
								<DataGrid.Columns>
									<DataGridCheckBoxColumn Header="Видим" Binding="{Binding Visible, Converter={StaticResource IntToBoolConverter}, Mode=TwoWay}" Width="70"/>
									<DataGridTextColumn Header="Заголовок столбца" Binding="{Binding Caption, Mode=TwoWay}" Width="1.5*"/>
									<DataGridTextColumn Header="Формула / Атрибут" Binding="{Binding DataFormula, Mode=TwoWay}" Width="2.5*"/>
									<DataGridTextColumn Header="Агрегация" Binding="{Binding Aggregate, Mode=TwoWay}" Width="100"/>
								</DataGrid.Columns>
							</DataGrid>
							<StackPanel Grid.Column="1" Spacing="8" Margin="12,0,0,0">
								<Button Classes="neutralButton commandButton" Command="{Binding AddColumnCommand}" Content="+ Поле"/>
								<Button Classes="neutralButton commandButton" Command="{Binding MoveColumnUpCommand}" CommandParameter="{Binding #FieldsGrid.SelectedItem}" Content="Выше"/>
								<Button Classes="neutralButton commandButton" Command="{Binding MoveColumnDownCommand}" CommandParameter="{Binding #FieldsGrid.SelectedItem}" Content="Ниже"/>
								<Button Classes="dangerButton commandButton" Command="{Binding RemoveColumnCommand}" CommandParameter="{Binding #FieldsGrid.SelectedItem}" Content="Удалить"/>
							</StackPanel>
						</Grid>
					</TabItem>
					<TabItem Header="Группировка" IsEnabled="False"><TextBlock Text="Будет реализовано позже" Margin="10" Foreground="{StaticResource SecondaryTextBrush}"/></TabItem>
					<TabItem Header="Вывод" IsEnabled="False"><TextBlock Text="Будет реализовано позже" Margin="10" Foreground="{StaticResource SecondaryTextBrush}"/></TabItem>
				</TabControl>
			</Grid>
		</Grid>

		<Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Margin="0,15,0,0">
			<Button Grid.Column="0" Classes="neutralButton" Click="ImportXmlClick" VerticalContentAlignment="Center" ToolTip.Tip="Импортировать XML Model Studio">
				<StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconFolder}" Width="14" Height="14" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Импорт XML"/></StackPanel>
			</Button>
			<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
				<Button Classes="accentButton" Command="{Binding ApplySettingsCommand}" Height="36" FontWeight="Bold" Padding="15,0" VerticalContentAlignment="Center" Content="Обновить" ToolTip.Tip="Обновить спецификацию по текущим настройкам"/>
				<Button Classes="neutralButton" Command="{Binding SaveXmlToDesktopCommand}" Height="36" Padding="12,0" VerticalContentAlignment="Center" Content="Сохранить XML" ToolTip.Tip="Сохранить профиль XML на рабочий стол"/>
				<Button Classes="neutralButton" Content="Закрыть" Click="CloseWindowClick" Width="90" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
			</StackPanel>
		</Grid>
	</Grid>
</Window>

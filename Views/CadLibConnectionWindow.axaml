<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibConnectionWindow"
        x:DataType="cadlib:CadLibConnectionViewModel"
        Title="Подключение к CADLib БД"
        Width="560"
        Height="520"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="16" Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="Подключение к базе данных CADLib Модель и Архив" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип СУБД:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Providers}" SelectedItem="{Binding ProviderKind}" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Host, Mode=TwoWay}" Watermark="localhost или адрес сервера" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Login, Mode=TwoWay}" Watermark="Имя пользователя" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" Watermark="Пароль" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Нормализация:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="14" Margin="10,0,0,8">
                        <CheckBox Content="Логин в нижний регистр" IsChecked="{Binding LowercaseLogin}" Foreground="{StaticResource TextBrush}"/>
                        <CheckBox Content="Пароль в нижний регистр" IsChecked="{Binding LowercasePassword}" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="База данных:" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Databases}" SelectedItem="{Binding SelectedDatabase}" Width="330" MinHeight="32" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="neutralButton" Content="Загрузить список баз" Command="{Binding LoadDatabasesCommand}"/>
                <Button Classes="accentButton" Content="Подключиться" Command="{Binding ConnectCommand}"/>
            </StackPanel>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" CornerRadius="4">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Classes="neutralButton" Content="Отмена" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>

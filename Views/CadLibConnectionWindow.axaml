<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibConnectionWindow"
        x:DataType="cadlib:CadLibConnectionViewModel"
        Title="Подключение к CADLib БД"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="Подключение к базе данных CADLib Модель и Архив" FontSize="16" FontWeight="Bold"/>

            <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип СУБД:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Providers}" SelectedItem="{Binding ProviderKind}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Host, Mode=TwoWay}" Watermark="localhost или адрес сервера"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт:" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Login, Mode=TwoWay}" Watermark="Имя пользователя"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" Watermark="Пароль"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Нормализация:" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="14">
                    <CheckBox Content="Логин в нижний регистр" IsChecked="{Binding LowercaseLogin}"/>
                    <CheckBox Content="Пароль в нижний регистр" IsChecked="{Binding LowercasePassword}"/>
                </StackPanel>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="База данных:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Databases}" SelectedItem="{Binding SelectedDatabase}" MinHeight="32"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Загрузить список баз" Command="{Binding LoadDatabasesCommand}"/>
                <Button Content="Подключиться" Command="{Binding ConnectCommand}"/>
            </StackPanel>

            <Border BorderBrush="#66888888" BorderThickness="1" Padding="10" CornerRadius="4">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Отмена" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>

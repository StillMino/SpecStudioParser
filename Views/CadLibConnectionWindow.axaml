<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibConnectionWindow"
        x:DataType="cadlib:CadLibConnectionViewModel"
        Title="Подключение к CADLib БД"
        Width="560"
        Height="500"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16" Background="{StaticResource AppBackgroundBrush}">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,10">
            <Border Grid.Column="0" Width="3" Background="{StaticResource AccentBrush}" Margin="0,2,8,2"/>
            <TextBlock Grid.Column="1" Text="CADLib БД" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип СУБД" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Providers}" SelectedItem="{Binding ProviderKind}" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Хост" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Host, Mode=TwoWay}" Watermark="localhost или адрес сервера" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Порт" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Port, Mode=TwoWay}" Minimum="1" Maximum="65535" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Login, Mode=TwoWay}" Watermark="Имя пользователя" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Password, Mode=TwoWay}" PasswordChar="●" Watermark="Пароль" Width="330" HorizontalAlignment="Left" Margin="10,0,0,8"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Регистр" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="14" Margin="10,0,0,8">
                    <CheckBox Content="Логин" IsChecked="{Binding LowercaseLogin}" Foreground="{StaticResource TextBrush}" ToolTip.Tip="Привести логин к нижнему регистру"/>
                    <CheckBox Content="Пароль" IsChecked="{Binding LowercasePassword}" Foreground="{StaticResource TextBrush}" ToolTip.Tip="Привести пароль к нижнему регистру"/>
                </StackPanel>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="База данных" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Databases}" SelectedItem="{Binding SelectedDatabase}" Width="330" MinHeight="32" HorizontalAlignment="Left" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,Auto" Margin="0,10,0,0">
            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10" CornerRadius="4" Margin="0,0,0,10">
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Classes="neutralButton" Command="{Binding LoadDatabasesCommand}" ToolTip.Tip="Загрузить список баз данных">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.96-.7 2.79l1.46 1.46A7.93 7.93 0 0 0 20 12c0-4.42-3.58-8-8-8z M6.7 9.21 5.24 7.75A7.93 7.93 0 0 0 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3c-3.31 0-6-2.69-6-6 0-1.01.25-1.96.7-2.79z" Fill="{StaticResource AccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Базы" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="accentButton" Command="{Binding ConnectCommand}" ToolTip.Tip="Подключиться к выбранной базе данных">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Data="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z" Fill="{StaticResource AccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        <TextBlock Text="Подключить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="neutralButton" Content="Отмена" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

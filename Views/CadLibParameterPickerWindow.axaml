<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibParameterPickerWindow"
        x:DataType="cadlib:CadLibParameterPickerViewModel"
        Title="Выбор параметра CADLib"
        Width="620"
        Height="560"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,150" Margin="12" Background="{StaticResource AppBackgroundBrush}">
        <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Поиск по группе, системному имени или отображаемому имени" Margin="0,0,10,10"/>

        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Spacing="8">
            <Button Classes="neutralButton commandButton" Content="{Binding SortButtonText}" Command="{Binding ToggleSortCommand}"/>
            <Button Classes="neutralButton commandButton" Content="Раскрыть группы" Command="{Binding ExpandAllCommand}"/>
            <Button Classes="neutralButton commandButton" Content="Скрыть группы" Command="{Binding CollapseAllCommand}"/>
            <Button Classes="accentButton commandButton" Content="{Binding NameModeButtonText}" Command="{Binding ToggleNameModeCommand}"/>
            <Separator Margin="0,4"/>
            <Button Classes="accentButton commandButton" Content="Выбрать" Command="{Binding SelectCommand}"/>
            <Button Classes="neutralButton commandButton" Content="Закрыть" Command="{Binding CloseCommand}"/>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,10,0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="cadlib:CadLibParameterGroupViewModel">
                            <Expander Header="{Binding Caption}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="6,4" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}">
                                <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="cadlib:CadLibParameterListItemViewModel">
                                            <Button Classes="neutralButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="8,2" Padding="8,5" Tag="{Binding Parameter}" Click="OnParameterClick">
                                                <Grid RowDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Row="0" Text="{Binding DisplayText}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                    <TextBlock Grid.Row="1" Text="{Binding DetailText}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Grid.Column="0" RowDefinitions="Auto,Auto" Margin="0,10,10,0">
            <TextBlock Grid.Row="0" Text="{Binding SelectedParameterText}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
            <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </Grid>
    </Grid>
</Window>

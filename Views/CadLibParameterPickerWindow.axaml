<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadlib="using:SpecStudioParser.CadLib"
        x:Class="SpecStudioParser.Views.CadLibParameterPickerWindow"
        x:DataType="cadlib:CadLibParameterPickerViewModel"
        Title="Выбор параметра CADLib"
        Width="560"
        Height="500"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,116" Margin="10" Background="{StaticResource AppBackgroundBrush}">
        <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Поиск по группе или параметру" Margin="0,0,8,8"/>

        <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Spacing="6">
            <Button Classes="neutralButton" Content="{Binding SortButtonText}" Command="{Binding ToggleSortCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
            <Button Classes="neutralButton" Content="Раскрыть" Command="{Binding ExpandAllCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
            <Button Classes="neutralButton" Content="Скрыть" Command="{Binding CollapseAllCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
            <Button Classes="neutralButton" Content="{Binding NameModeButtonText}" Command="{Binding ToggleNameModeCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
            <Separator Margin="0,2"/>
            <Button Classes="accentButton" Content="Выбрать" Command="{Binding SelectCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
            <Button Classes="neutralButton" Content="Закрыть" Command="{Binding CloseCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8,5"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Background="{StaticResource PanelBrush}">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="cadlib:CadLibParameterGroupViewModel">
                        <Expander Header="{Binding Caption}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,1" Padding="0" Foreground="{StaticResource TextBrush}">
                            <ItemsControl ItemsSource="{Binding Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="cadlib:CadLibParameterListItemViewModel">
                                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="18,0,0,1" Padding="6,3" Background="Transparent" BorderThickness="0" Tag="{Binding Parameter}" Click="OnParameterClick">
                                            <Grid RowDefinitions="Auto,Auto">
                                                <TextBlock Grid.Row="0" Text="{Binding DisplayText}" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Grid.Row="1" Text="{Binding DetailText}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Grid.Column="0" RowDefinitions="Auto,Auto" Margin="0,8,8,0">
            <TextBlock Grid.Row="0" Text="{Binding SelectedParameterText}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
            <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </Grid>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecStudioParser.DesignTools.ViewModels"
        xmlns:conv="using:SpecStudioParser.DesignTools.Converters"
        x:Class="SpecStudioParser.DesignTools.Views.DesignToolsWindow"
        x:DataType="vm:DesignToolsViewModel"
        Title="Инструменты проектировщика"
        Width="420"
        Height="640"
        MinWidth="340"
        MinHeight="480"
        Background="{StaticResource AppBackgroundBrush}">

	<Window.Resources>
		<conv:GeometryPathConverter x:Key="GeometryPathConverter"/>
	</Window.Resources>

	<Grid RowDefinitions="Auto, *, Auto" Background="{StaticResource AppBackgroundBrush}">
		<Border Grid.Row="0"
		        Background="{StaticResource PanelBrush}"
		        BorderBrush="{StaticResource BorderBrush}"
		        BorderThickness="0,0,0,1"
		        Padding="8">
			<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
				<TextBlock Grid.Column="0"
				           Grid.Row="0"
				           Text="Инструменты проектировщика"
				           FontSize="15"
				           FontWeight="Bold"
				           Foreground="{StaticResource TextBrush}"/>

				<Button Grid.Column="1"
				        Grid.Row="0"
				        Classes="neutralButton"
				        Command="{Binding RefreshContextCommand}"
				        Padding="6,2"
				        ToolTip.Tip="Обновить сведения об активном документе nanoCAD">
					<TextBlock Text="↻" FontSize="13"/>
				</Button>

				<TextBlock Grid.Column="0"
				           Grid.ColumnSpan="2"
				           Grid.Row="1"
				           Text="{Binding DocumentStatus}"
				           Margin="0,4,0,0"
				           TextWrapping="NoWrap"
				           TextTrimming="CharacterEllipsis"
				           FontSize="11"
				           Foreground="{StaticResource SecondaryTextBrush}"/>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" Margin="6">
			<ItemsControl ItemsSource="{Binding Blocks}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:DesignToolBlockViewModel">
						<Border Background="{StaticResource PanelBrush}"
						        BorderBrush="{StaticResource BorderBrush}"
						        BorderThickness="1"
						        CornerRadius="4"
						        Padding="6"
						        Margin="0,0,0,6">
							<Grid RowDefinitions="Auto, Auto">
								<Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,5">
									<TextBlock Grid.Column="0"
									           Text="{Binding Name}"
									           FontSize="12"
									           FontWeight="Bold"
									           Foreground="{StaticResource TextBrush}"
									           ToolTip.Tip="{Binding Description}"/>

									<CheckBox Grid.Column="1"
									          IsChecked="{Binding IsEnabled}"
									          VerticalAlignment="Center"
									          ToolTip.Tip="Включить или выключить блок функций"/>
								</Grid>

								<ItemsControl Grid.Row="1" ItemsSource="{Binding Features}">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:DesignToolFeatureViewModel">
											<Border BorderBrush="{StaticResource BorderBrush}"
											        BorderThickness="0,0,0,1"
											        Padding="0,3">
												<Grid ColumnDefinitions="Auto, *, Auto, Auto" RowDefinitions="Auto">
													<Button Grid.Column="0"
													        Command="{Binding RunCommand}"
													        IsEnabled="{Binding IsEnabled}"
													        Width="30"
													        Height="30"
													        Padding="3"
													        Margin="0,0,6,0"
													        Background="{StaticResource AccentSoftBrush}"
													        ToolTip.Tip="{Binding Description}">
														<Viewbox Width="22" Height="22" Stretch="Uniform">
															<Path Data="{Binding IconGeometry, Converter={StaticResource GeometryPathConverter}}"
															      Stroke="{StaticResource TextBrush}"
															      StrokeThickness="1.3"
															      StrokeLineCap="Round"
															      StrokeJoin="Round"
															      Fill="Transparent"/>
														</Viewbox>
													</Button>

													<TextBlock Grid.Column="1"
													           Text="{Binding Name}"
													           VerticalAlignment="Center"
													           TextWrapping="NoWrap"
													           TextTrimming="CharacterEllipsis"
													           FontSize="12"
													           FontWeight="SemiBold"
													           Foreground="{StaticResource TextBrush}"
													           ToolTip.Tip="{Binding Description}"/>

													<Border Grid.Column="2"
													        Background="{StaticResource AccentSoftBrush}"
													        CornerRadius="3"
													        Padding="4,1"
													        Margin="6,0,0,0"
													        VerticalAlignment="Center">
														<TextBlock Text="{Binding ContextLabel}" FontSize="10" Foreground="{StaticResource TextBrush}"/>
													</Border>

													<TextBlock Grid.Column="3"
													           Text="{Binding Status}"
													           Width="70"
													           Margin="6,0,0,0"
													           VerticalAlignment="Center"
													           TextAlignment="Right"
													           TextWrapping="NoWrap"
													           TextTrimming="CharacterEllipsis"
													           FontSize="10"
													           Foreground="{StaticResource SecondaryTextBrush}"
													           ToolTip.Tip="{Binding Status}"/>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<Border Grid.Row="2"
		        Background="{StaticResource PanelBrush}"
		        BorderBrush="{StaticResource BorderBrush}"
		        BorderThickness="0,1,0,0"
		        Padding="7">
			<TextBlock Text="{Binding Status}"
			           TextWrapping="NoWrap"
			           TextTrimming="CharacterEllipsis"
			           FontSize="11"
			           Foreground="{StaticResource TextBrush}"/>
		</Border>
	</Grid>
</Window>

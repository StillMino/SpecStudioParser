<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecStudioParser.DesignTools.ViewModels"
        xmlns:conv="using:SpecStudioParser.DesignTools.Converters"
        x:Class="SpecStudioParser.DesignTools.Views.DesignToolsWindow"
        x:DataType="vm:DesignToolsViewModel"
        Title="Инструменты проектировщика"
        Width="460"
        Height="720"
        MinWidth="360"
        MinHeight="520"
        Background="{StaticResource AppBackgroundBrush}">

	<Window.Resources>
		<conv:GeometryPathConverter x:Key="GeometryPathConverter"/>
	</Window.Resources>

	<Grid RowDefinitions="Auto, *, Auto" Background="{StaticResource AppBackgroundBrush}">
		<Border Grid.Row="0"
		        Background="{StaticResource PanelBrush}"
		        BorderBrush="{StaticResource BorderBrush}"
		        BorderThickness="0,0,0,1"
		        Padding="12">
			<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
				<StackPanel Grid.Column="0" Grid.Row="0" Spacing="2">
					<TextBlock Text="Инструменты проектировщика"
					           FontSize="18"
					           FontWeight="Bold"
					           Foreground="{StaticResource TextBrush}"/>
					<TextBlock Text="Панель быстрых 2D/3D-функций. Спецификатор не изменяется."
					           TextWrapping="Wrap"
					           FontSize="11"
					           Foreground="{StaticResource SecondaryTextBrush}"/>
				</StackPanel>

				<Button Grid.Column="1"
				        Grid.Row="0"
				        Classes="neutralButton"
				        Command="{Binding RefreshContextCommand}"
				        VerticalAlignment="Top"
				        ToolTip.Tip="Обновить сведения об активном документе nanoCAD">
					<TextBlock Text="Обновить"/>
				</Button>

				<TextBlock Grid.Column="0"
				           Grid.ColumnSpan="2"
				           Grid.Row="1"
				           Text="{Binding DocumentStatus}"
				           Margin="0,10,0,0"
				           TextWrapping="Wrap"
				           FontSize="12"
				           Foreground="{StaticResource SecondaryTextBrush}"/>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" Margin="10">
			<ItemsControl ItemsSource="{Binding Blocks}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:DesignToolBlockViewModel">
						<Border Background="{StaticResource PanelBrush}"
						        BorderBrush="{StaticResource BorderBrush}"
						        BorderThickness="1"
						        CornerRadius="4"
						        Padding="10"
						        Margin="0,0,0,10">
							<Grid RowDefinitions="Auto, Auto, Auto">
								<Grid Grid.Row="0" ColumnDefinitions="*, Auto">
									<StackPanel Grid.Column="0" Spacing="2">
										<TextBlock Text="{Binding Name}"
										           FontWeight="Bold"
										           Foreground="{StaticResource TextBrush}"/>
										<TextBlock Text="{Binding Description}"
										           TextWrapping="Wrap"
										           FontSize="11"
										           Foreground="{StaticResource SecondaryTextBrush}"/>
									</StackPanel>

									<CheckBox Grid.Column="1"
									          IsChecked="{Binding IsEnabled}"
									          VerticalAlignment="Top"
									          ToolTip.Tip="Включить или выключить блок функций"/>
								</Grid>

								<Separator Grid.Row="1" Margin="0,8"/>

								<ItemsControl Grid.Row="2" ItemsSource="{Binding Features}">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:DesignToolFeatureViewModel">
											<Border BorderBrush="{StaticResource BorderBrush}"
											        BorderThickness="0,0,0,1"
											        Padding="0,7">
												<Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *, Auto">
													<Border Grid.Row="0"
													        Grid.Column="0"
													        Grid.RowSpan="3"
													        Width="28"
													        Height="28"
													        Margin="0,0,8,0"
													        Background="{StaticResource AccentSoftBrush}"
													        CornerRadius="3">
														<Viewbox Width="22" Height="22" Stretch="Uniform">
															<Path Data="{Binding IconGeometry, Converter={StaticResource GeometryPathConverter}}"
															      Stroke="{StaticResource TextBrush}"
															      StrokeThickness="1.3"
															      StrokeLineCap="Round"
															      StrokeJoin="Round"
															      Fill="Transparent"/>
														</Viewbox>
													</Border>

													<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
														<TextBlock Text="{Binding Name}"
														           FontWeight="SemiBold"
														           Foreground="{StaticResource TextBrush}"/>
														<Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="4,1">
															<TextBlock Text="{Binding AccessLabel}" FontSize="10" Foreground="{StaticResource TextBrush}"/>
														</Border>
														<Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="4,1">
															<TextBlock Text="{Binding ContextLabel}" FontSize="10" Foreground="{StaticResource TextBrush}"/>
														</Border>
													</StackPanel>

													<Button Grid.Row="0"
													        Grid.Column="2"
													        Classes="accentButton"
													        Command="{Binding RunCommand}"
													        IsEnabled="{Binding IsEnabled}"
													        Padding="8,4">
														<TextBlock Text="Запуск"/>
													</Button>

													<TextBlock Grid.Row="1"
													           Grid.Column="1"
													           Grid.ColumnSpan="2"
													           Text="{Binding Description}"
													           TextWrapping="Wrap"
													           Margin="0,4,0,0"
													           FontSize="11"
													           Foreground="{StaticResource SecondaryTextBrush}"/>

													<TextBlock Grid.Row="2"
													           Grid.Column="1"
													           Grid.ColumnSpan="2"
													           Text="{Binding Status}"
													           TextWrapping="Wrap"
													           Margin="0,4,0,0"
													           FontSize="11"
													           Foreground="{StaticResource SecondaryTextBrush}"/>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<Border Grid.Row="2"
		        Background="{StaticResource PanelBrush}"
		        BorderBrush="{StaticResource BorderBrush}"
		        BorderThickness="0,1,0,0"
		        Padding="10">
			<TextBlock Text="{Binding Status}"
			           TextWrapping="Wrap"
			           FontSize="12"
			           Foreground="{StaticResource TextBrush}"/>
		</Border>
	</Grid>
</Window>

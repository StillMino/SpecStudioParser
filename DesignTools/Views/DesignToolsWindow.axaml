<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpecStudioParser.DesignTools.ViewModels"
        xmlns:conv="using:SpecStudioParser.DesignTools.Converters"
        x:Class="SpecStudioParser.DesignTools.Views.DesignToolsWindow"
        x:DataType="vm:DesignToolsViewModel"
        Title="Инструменты проектировщика"
        Width="420"
        Height="640"
        MinWidth="340"
        MinHeight="480"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="{StaticResource AppBackgroundBrush}">

	<Window.Resources>
		<conv:GeometryPathConverter x:Key="GeometryPathConverter"/>
	</Window.Resources>

	<Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Background="{StaticResource AppBackgroundBrush}">
		<Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8">
			<Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
				<TextBlock Grid.Column="0" Grid.Row="0" Text="Инструменты проектировщика" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
				<Button Grid.Column="1" Grid.Row="0" Classes="neutralButton" Command="{Binding RefreshContextCommand}" Padding="6,2" ToolTip.Tip="Обновить сведения об активном документе nanoCAD">
					<TextBlock Text="↻" FontSize="13"/>
				</Button>
				<TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Text="{Binding DocumentStatus}" Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"/>
			</Grid>
		</Border>

		<Border Grid.Row="1" Padding="6,5,6,2" Background="{StaticResource AppBackgroundBrush}">
			<WrapPanel Orientation="Horizontal">
				<Button Content="Все" Command="{Binding SelectFilterCommand}" CommandParameter="all" Padding="8,3" Margin="0,0,4,3" ToolTip.Tip="Показать все инструменты"/>
				<Button Content="2D" Command="{Binding SelectFilterCommand}" CommandParameter="drafting" Padding="8,3" Margin="0,0,4,3" ToolTip.Tip="Инструменты 2D-проектирования"/>
				<Button Content="Диагностика" Command="{Binding SelectFilterCommand}" CommandParameter="diagnostics" Padding="8,3" Margin="0,0,4,3" ToolTip.Tip="Служебные диагностические инструменты"/>
				<Button Content="3D" Command="{Binding SelectFilterCommand}" CommandParameter="model" Padding="8,3" Margin="0,0,4,3" ToolTip.Tip="Инструменты модели"/>
				<Button Content="Spec" Command="{Binding SelectFilterCommand}" CommandParameter="specifier" Padding="8,3" Margin="0,0,4,3" ToolTip.Tip="Связь со спецификатором"/>
			</WrapPanel>
		</Border>

		<Border Grid.Row="2" Padding="6,2,6,5" Background="{StaticResource AppBackgroundBrush}">
			<TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
			         Watermark="Поиск инструмента или режима"
			         FontSize="12"
			         MinHeight="28"
			         ToolTip.Tip="Поиск по названию инструмента, описанию и параметрам"/>
		</Border>

		<ScrollViewer Grid.Row="3" Margin="6,0,6,6">
			<ItemsControl ItemsSource="{Binding ToolCards}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:DesignToolCardViewModel">
						<Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
							<Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *">
								<Button Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Command="{Binding RunCommand}" Width="34" Height="34" Padding="4" Margin="0,0,7,0" Background="{StaticResource AccentSoftBrush}" ToolTip.Tip="Запустить инструмент">
									<Viewbox Width="24" Height="24" Stretch="Uniform">
										<Path Data="{Binding IconGeometry, Converter={StaticResource GeometryPathConverter}}" Stroke="{StaticResource TextBrush}" StrokeThickness="1.3" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"/>
									</Viewbox>
								</Button>

								<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Description}"/>

								<Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*, *, *, *" Margin="0,5,0,0">
									<ComboBox Grid.Column="0" ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" FontSize="11" MinHeight="26" Margin="0,0,4,0"/>
									<ComboBox Grid.Column="1" ItemsSource="{Binding Operations}" SelectedItem="{Binding SelectedOperation}" FontSize="11" MinHeight="26" Margin="0,0,4,0"/>
									<ComboBox Grid.Column="2" ItemsSource="{Binding Axes}" SelectedItem="{Binding SelectedAxis}" FontSize="11" MinHeight="26" Margin="0,0,4,0"/>
									<ComboBox Grid.Column="3" ItemsSource="{Binding References}" SelectedItem="{Binding SelectedReference}" FontSize="11" MinHeight="26"/>
								</Grid>

								<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="10" Foreground="{StaticResource SecondaryTextBrush}" ToolTip.Tip="{Binding Status}"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<Border Grid.Row="4" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="7">
			<TextBlock Text="{Binding Status}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="{StaticResource TextBrush}"/>
		</Border>
	</Grid>
</Window>
